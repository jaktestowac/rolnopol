# Possible providers: openrouter, gemini, mock
CHATBOT_LLM_PROVIDER=mock
# set to 0 to disable logging of LLM requests and responses in the console. 
# Max verbosity is 2, which logs the full request and response objects. 
# Setting to 1 logs only the prompt and response text.
LLM_CONSOLE_LOG_LEVEL=0

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
GEMINI_RETRIES=2

# OpenRouter
# https://openrouter.ai/models?order=pricing-low-to-high
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=openrouter/free
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=30000
OPENROUTER_RETRIES=2

# LLM Assistant Function Calling
# The assistant can call tools to fetch additional data (weather, alerts, commodities, etc.)
CHATBOT_ENABLE_FUNCTION_CALLS=true
OPENROUTER_TIMEOUT_MS=30000
OPENROUTER_RETRIES=2