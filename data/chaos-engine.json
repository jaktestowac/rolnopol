        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE"
      ],
      "excludePaths": [
        "/v1/chaos-engine*",
        "/v1/healthcheck",
        "/version",
        "/metrics",
        "/admin",
        "/feature-flags"
