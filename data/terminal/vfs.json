{
  "name": "/",
  "children": {
    "configs": {
      "children": {
        "terminal.json": {
          "title": "Terminal Config",
          "type": "json",
          "content": {
            "prompt": "guest@archive:~$",
            "theme": "green",
            "effects": true,
            "autoScroll": true
          }
        },
        "themes": {
          "children": {
            "green.json": {
              "title": "Green Theme",
              "type": "json",
              "content": {
                "name": "green",
                "foreground": "#66ff99",
                "background": "#04110a"
              }
            },
            "amber.json": {
              "title": "Amber Theme",
              "type": "json",
              "content": {
                "name": "amber",
                "foreground": "#ffcc66",
                "background": "#120d04"
              }
            }
          }
        }
      }
    },
    "docs": {
      "children": {
        "readme.md": {
          "title": "Terminal README",
          "type": "text",
          "content": "This is a sample virtual filesystem used by the terminal API. Edit JSON files under data/terminal to modify content."
        },
        "guide": {
          "children": {
            "filesystem.md": {
              "title": "Filesystem Guide",
              "type": "text",
              "content": "Use ls to inspect directories, cd to move, pwd to show the current path, and tree to print nested folders."
            },
            "commands.md": {
              "title": "Command Guide",
              "type": "text",
              "content": "Terminal commands are served by the backend and can be synced from disk with /terminal/sync."
            },
            "restricted.md": {
              "title": "Restricted Guide",
              "type": "text",
              "access": "password",
              "password": "amber",
              "passwordHint": "Look for the warmer archive light.",
              "content": "This guide is protected and can only be opened with the correct password."
            },
            "release-notes.md": {
              "title": "Release Notes",
              "type": "text",
              "content": "- Added disk-backed scripts\n- Added nested VFS samples\n- Added sync endpoint"
            },
            "secret-index.md": {
              "title": "Secret Index",
              "type": "text",
              "secret": true,
              "content": "This hidden index maps the quiet corners of the archive and only appears in verbose all-files listings."
            }
          }
        }
      }
    },
    "logs": {
      "children": {
        "system.log": {
          "title": "System Log",
          "type": "text",
          "content": "[00:00] boot sequence initiated\n[00:01] registry synced\n[00:02] terminal ready\n"
        },
        "boot.log": {
          "title": "Boot Log",
          "type": "text",
          "content": "[00:00] init\n[00:00] load scripts\n[00:01] mount vfs\n[00:02] shell online\n"
        },
        "api": {
          "children": {
            "requests.log": {
              "title": "API Requests",
              "type": "text",
              "content": "GET /api/v1/terminal/commands 200\nPOST /api/v1/terminal/execute 200\nPOST /api/v1/terminal/sync 200\n"
            }
          }
        }
      }
    },
    "vault": {
      "access": "password",
      "password": "ember",
      "passwordHint": "The archive remembers the color of fire.",
      "children": {
        "manifest.txt": {
          "title": "Vault Manifest",
