{
  "name": "rolnopol-app",
  "version": "1.49.0",
  "description": "A Rolnopol app with JSON database, authentication, and admin panel",
  "main": "api/index.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test vitest run --dir tests",
    "unit": "vitest run --dir tests/unit",
    "pbt": "cross-env NODE_ENV=test vitest run --environment=node --project property",
    "start": "node ./api/index.js",
    "start-debug": "cross-env DEBUG_MODE=true node ./api/index.js",
    "dev": "node ./api/index.js",
    "greenhouse": "node ./grpc/greenhouse-server/index.js",
    "greenhouse:health": "node ./grpc/client-health.js",
    "greenhouse:plant": "node ./grpc/client-plant.js",
    "greenhouse:test": "cross-env NODE_ENV=test vitest run tests/unit/greenhouse.service.test.js tests/unit/greenhouse.tick-engine.test.js && cross-env NODE_ENV=test vitest run tests/greenhouse-grpc.test.js tests/greenhouse-rest.test.js tests/greenhouse-pages-gating.test.js",
    "tasklab": "node ./grpc/tasklab-server/index.js",
    "tasklab:demo": "node ./grpc/client-tasklab.js",
    "tasklab:test": "cross-env NODE_ENV=test vitest run tests/unit/tasklab.service.test.js && cross-env NODE_ENV=test vitest run tests/tasklab-grpc.test.js tests/tasklab-rest.test.js tests/tasklab-pages-gating.test.js",
    "farmstay": "node ./external-services/farm-stay/start-all.js",
    "farmstay:kill": "node ./external-services/farm-stay/kill-all.js",
    "farmstay:gateway": "node ./external-services/farm-stay/stay-gateway-service/server/index.js",
    "farmstay:inventory": "node ./external-services/farm-stay/inventory-service/server/index.js",
    "farmstay:pricing": "node ./external-services/farm-stay/pricing-service/server/index.js",
    "farmstay:reservation": "node ./external-services/farm-stay/reservation-service/server/index.js",
    "farmstay:reviews": "node ./external-services/farm-stay/review-desk-service/server/index.js",
    "farmstay:control": "node ./external-services/farm-stay/control.js",
    "farmstay:demo": "node ./external-services/farm-stay/stay-gateway-service/client-demo.js",
    "farmstay:kill-ports": "call ./external-services/farm-stay/kill-ports.bat",
    "format": "npx prettier --write .",
    "bump-version": "node bump-version.js minor"
  },
  "keywords": [
    "express",
    "api",
    "rolnopol",
    "json-database",
    "authentication",
    "admin"
  ],
  "author": "Rolnopol",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "supertest": "^7.1.3",
    "vitest": "^4.1.8"
  }
}
